// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------
// 1. USER MODEL (Multi-Tenant Architecture)
// -------------------------------------------------
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed password
  tier      Tier     @default(FREE) // For rate-limiting and billing
  
  apiKeys   ApiKey[] // One-to-Many: A user can have multiple API keys
  assets    Asset[]  // One-to-Many: A user owns multiple uploaded files

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  webhookUrl    String?  
  webhookSecret String?
}

enum Tier {
  FREE
  PRO
  ENTERPRISE
}

// -------------------------------------------------
// 2. API KEY MODEL (Security & Auth)
// -------------------------------------------------
model ApiKey {
  id         String   @id @default(uuid())
  name       String   // e.g., "Production Key", "Development Key"
  keyHash    String   @unique // The Bcrypt hashed version of the actual key
  maskedKey  String   // To show in the UI: e.g., "sk_test_****8f92"
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  
  @@index([userId]) // Index for faster lookups when authenticating requests
}

// -------------------------------------------------
// 3. ASSET TRACKING MODEL (State Management)
// -------------------------------------------------
model Asset {
  id           String      @id @default(uuid())
  originalName String      // e.g., "raw-video-upload.mp4"
  minioUrl     String      // The internal path in your Minio bucket
  fileSize     Int         // Stored in bytes
  
  // This state is crucial for background workers!
  status       AssetStatus @default(PENDING) 
  
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  @@index([userId])
}

enum AssetStatus {
  PENDING     // Uploaded, waiting in the Redis queue
  PROCESSING  // Worker is currently handling it (e.g., transcoding to HLS)
  COMPLETED   // Ready to be served via CDN
  FAILED      // Worker encountered an error
}
